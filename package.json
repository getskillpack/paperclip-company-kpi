{
  "name": "@getskillpack/paperclip-company-kpi",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "description": "Paperclip plugin: company KPI / cost rollup + manual ledger",
  "repository": {
    "type": "git",
    "url": "https://github.com/getskillpack/paperclip-company-kpi.git"
  },
  "bugs": {
    "url": "https://github.com/getskillpack/paperclip-company-kpi/issues"
  },
  "homepage": "https://github.com/getskillpack/paperclip-company-kpi",
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "dev:ui": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4177",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "keywords": ["paperclip", "plugin", "ui", "kpi", "budget"],
  "author": "getskillpack",
  "license": "MIT",
  "devDependencies": {
    "@paperclipai/plugin-sdk": "^2026.325.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "esbuild": "^0.27.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
